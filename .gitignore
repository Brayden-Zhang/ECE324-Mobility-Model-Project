# Virtual environment
/.venv/

# Python bytecode
__pycache__/
*.pyc

# Slurm job logs
slurm-*.out

# HuggingFace cache
/.hf_cache/

# Experiment result cache
/cache/

# Model checkpoints & weights
/checkpoints/
*.pt

# Allow committing selected "best" checkpoints (override above)
!/checkpoints/
!checkpoints/hmt_nohash_full_step_25000.pt
!checkpoints/hmt_nohash_full_step_20000.pt
!checkpoints/hmt_nohash_full_step_15000.pt
!checkpoints/hmt_step_15000.pt
!checkpoints/hmt_step_10000.pt
!checkpoints/hmt_final_step_1.pt

# Data files
/data/

# External cloned repos
/external/

# Docs (local notes/drafts)
/docs/

# Optional extension modules not in paper scope
train_geosight.py
train_metabolic.py
train_privamove.py
train_socialmob.py
utils/geosight.py
utils/metabolic.py
utils/privamove.py
utils/socialmob.py
scripts/slurm_train_geosight.sh
scripts/slurm_train_metabolic.sh
scripts/slurm_train_privamove.sh
scripts/slurm_train_socialmob.sh
