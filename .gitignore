# Virtual environment
/.venv/

# Python bytecode
__pycache__/
*.py[cod]

# Runtime outputs
slurm-*.out
run.log
results.tsv
*.nfs*
*.tmp
*.bak
*.orig
*.rej
*.swp
*.swo

# Local caches and downloads
/.hf_cache/
/cache/
/external/
/tmp/
/artifacts/
/outputs/
/wandb/

# Keep tests/scripts code tracked; ignore generated outputs only
tests/**/tmp/
tests/**/outputs/
tests/**/*.golden.generated*
scripts/**/tmp/
scripts/**/*.generated.*

# Checkpoints and local weights
/model.pt
/checkpoints/*.pt
/checkpoints/**/*.pt

# Large local datasets
data/hdx/
data/worldtrace/
data/worldtrace_full/
data/raw/
data/**/*.zip
data/**/*.tar
data/**/*.tar.gz
data/**/*.parquet
data/**/*.feather

# LaTeX build artifacts
docs/*.aux
docs/*.bbl
docs/*.blg
docs/*.fdb_latexmk
docs/*.fls
docs/*.log
docs/*.out
docs/*.stdout
docs/_minted-*/

# Shell/script byproducts (keep real scripts tracked)
*.sh.log
*.sh.out
*.sh.err
scripts/*.local.sh
